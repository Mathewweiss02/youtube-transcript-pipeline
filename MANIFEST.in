include CHANGELOG.md
include GETTING_STARTED.md
include LICENSE
include README.md
exclude yt_processor/*.json
exclude yt_processor/*.md
recursive-exclude yt_processor/legacy_scripts_backup *
recursive-exclude yt_processor/notebooklm_bundles *
recursive-exclude yt_processor/reports *
